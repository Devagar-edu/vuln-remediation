# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx
GITHUB_ORG=your-org
GOVERNANCE_REPO=vuln-governance          # repo that stores memory / audit / plans

# GitHub Models (gpt-4o-mini via Azure OpenAI-compatible endpoint)
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODELS_TOKEN=ghp_xxxxxxxxxxxxxxxx
GITHUB_MODELS_MODEL=gpt-4o-mini

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourorg.atlassian.net
JIRA_USER=automation@yourorg.com
JIRA_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=VULN

# ── Orchestrator ──────────────────────────────────────────────────────────────
WEBHOOK_SECRET=replace-with-32-char-random-string
WEBHOOK_PORT=8080

# ── Snyk ──────────────────────────────────────────────────────────────────────
SNYK_TOKEN=your-snyk-token
SNYK_ORG=your-snyk-org-slug

# ── Behaviour ─────────────────────────────────────────────────────────────────
# Build fails when any vuln at this severity or above is found
FAIL_ON_SEVERITY=high          # critical | high | medium | low
MAX_FIX_ATTEMPTS=3             # after this, issue is escalated to human
